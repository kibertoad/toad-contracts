    "single",
    "source",
    "standard-schema",
    "truth"
  ],
  "homepage": "https://github.com/kibertoad/toad-contracts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kibertoad/toad-contracts.git",
    "directory": "packages/arktype"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
