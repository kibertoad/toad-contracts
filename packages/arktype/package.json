    "@toad-contracts/messages": "workspace:*",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.10",
    "arktype": "^2.1.0",
    "rimraf": "^6.1.2",
    "typescript": "7.0.1-rc",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "arktype": ">=2.0.0"
