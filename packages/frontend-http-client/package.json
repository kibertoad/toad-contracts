{
  "name": "@toad-contracts/frontend-http-client",
  "version": "0.3.2",
  "private": false,
  "description": "Opinionated wretch-based HTTP client driven by @toad-contracts standard-schema contracts",
  "keywords": [
    "api",
    "browser",
    "client",
    "contract",
    "contracts",
    "frontend",
    "http",
    "standard-schema",
    "typesafe",
    "wretch"
  ],
  "homepage": "https://github.com/kibertoad/toad-contracts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kibertoad/toad-contracts.git",
    "directory": "packages/frontend-http-client"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "lint": "oxlint && oxfmt --check . && tsc",
    "lint:fix": "oxlint --fix && oxfmt .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@toad-contracts/core": "workspace:*",
    "fast-querystring": "^1.1.2",
    "parse-sse": "^0.1.0"
  },
  "devDependencies": {
    "@lokalise/tsconfig": "^5.0.0",
    "@toad-contracts/valibot": "workspace:*",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "mockttp": "^4.4.2",
    "rimraf": "^6.1.3",
    "typescript": "7.0.1-rc",
    "valibot": "^1.4.1",
    "vitest": "^4.1.9",
    "wretch": "^3.0.9"
  },
  "peerDependencies": {
    "wretch": "^3.0.0"
  }
}
