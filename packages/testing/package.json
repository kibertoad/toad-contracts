{
  "name": "@toad-contracts/testing",
  "version": "0.3.2",
  "private": false,
  "description": "Testing utilities for mocking @toad-contracts HTTP responses with mockttp and msw",
  "keywords": [
    "api",
    "backend",
    "contract",
    "contracts",
    "frontend",
    "mock",
    "mocking",
    "mockttp",
    "msw",
    "standard-schema",
    "testing"
  ],
  "homepage": "https://github.com/kibertoad/toad-contracts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/kibertoad/toad-contracts.git",
    "directory": "packages/testing"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && tsc --project tsconfig.build.json",
    "lint": "oxlint && oxfmt --check . && tsc",
    "lint:fix": "oxlint --fix && oxfmt .",
    "test": "vitest run",
    "test:ci": "vitest run --coverage"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "@toad-contracts/core": "workspace:*"
  },
  "devDependencies": {
    "@lokalise/tsconfig": "^5.0.0",
    "@toad-contracts/valibot": "workspace:*",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "mockttp": "^4.4.2",
    "msw": "^2.13.2",
    "rimraf": "^6.1.2",
    "typescript": "7.0.1-rc",
    "valibot": "^1.4.1",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "mockttp": ">=4.0.0",
    "msw": ">=2.7.0"
  },
  "peerDependenciesMeta": {
    "mockttp": {
      "optional": true
    },
    "msw": {
      "optional": true
    }
  }
}
